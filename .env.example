# AfriFarmAI configuration — placeholders only, never commit real secrets.

# The app always calls the live providers below; all keys are required for
# full functionality. A missing key surfaces as an error to the user (no stubs).

# Hugging Face — Inference for ASR (Whisper) of Swahili.
HF_TOKEN=

# NVIDIA build.nvidia.com — Nemotron 3 Nano Omni 30B-A3B (vision + reasoning).
NVIDIA_API_KEY=
NEMOTRON_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning
NEMOTRON_BASE_URL=https://integrate.api.nvidia.com/v1
# Compatibility names used by the standalone NVIDIA chat client.
NVIDIA_MODEL_NAME=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Cohere — Tiny Aya for Swahili translation + localization.
# API model names: tiny-aya-earth (African langs), tiny-aya-global, etc.
COHERE_API_KEY=
TINY_AYA_MODEL=tiny-aya-earth

# Google Maps Platform — Places API (New).
# Keep this server-side only. Never expose it in frontend JavaScript.
GOOGLE_PLACES_API_KEY=

# Modal VoxCPM2 TTS endpoint and proxy-auth credentials.
# Keep credentials server-side only. Use the deployed non-dev URL in production.
MODAL_TTS_URL=
MODAL_KEY=
MODAL_SECRET=
MODAL_TTS_TIMEOUT_SECONDS=300

# Speech-to-text routes by language:
#  * English -> Cohere Transcribe (needs COHERE_API_KEY)
#  * Swahili -> Whisper via HF Inference (needs HF_TOKEN)
ASR_MODEL=openai/whisper-large-v3
COHERE_TRANSCRIBE_MODEL=cohere-transcribe-03-2026

# Request timeouts (seconds) and confidence gate for safe fallbacks.
PROVIDER_TIMEOUT_SECONDS=30
MIN_CONFIDENCE=0.45
