# AfriFarmAI configuration — placeholders only, never commit real secrets.

# Global toggle: "false" uses local stubs (default, runs with no keys);
# "true" routes to real Path A providers (requires keys below).
USE_REAL_MODELS=false

# Per-provider overrides (each defaults to USE_REAL_MODELS). Use these to turn
# real models on one at a time. Providers not yet wired safely fall back to the
# stub even when set to true.
# USE_REAL_NEMOTRON=true   # wired
# USE_REAL_STT=false       # not wired yet (falls back to stub)
# USE_REAL_AYA=false       # not wired yet (falls back to stub)
# USE_REAL_TTS=false       # not wired yet (falls back to stub)

# Hugging Face — Spaces / Inference for ASR (Whisper or MMS) and Nemotron Omni.
HF_TOKEN=

# NVIDIA build.nvidia.com — Nemotron 3 Nano Omni 30B-A3B (vision + reasoning).
NVIDIA_API_KEY=
NEMOTRON_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning
NEMOTRON_BASE_URL=https://integrate.api.nvidia.com/v1

# Cohere — Tiny Aya for Swahili/Dholuo translation + localization.
# API model names: tiny-aya-earth (African langs), tiny-aya-global, etc.
COHERE_API_KEY=
TINY_AYA_MODEL=tiny-aya-earth

# ASR model id served via HF Inference (Whisper auto-detects Swahili; swap to a
# fine-tuned checkpoint or MMS for Dholuo later). Needs HF_TOKEN above.
ASR_MODEL=openai/whisper-large-v3

# Request timeouts (seconds) and confidence gate for safe fallbacks.
PROVIDER_TIMEOUT_SECONDS=30
MIN_CONFIDENCE=0.45
